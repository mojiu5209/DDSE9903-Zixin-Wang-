  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::EndingScrollSequence
  blackFade: {fileID: 1838452419}
  endingText: {fileID: 1768632131}
  endingMessage: "As I watched my dog running toward me, I felt like I had seen this
    scene countless times before. Memories came flooding back like a rushing spring,
    and I remembered all the moments we had spent relying on each other. I\u2019m
    so happy to meet you again, and I know we will share many more joyful memories
    in the future.\r\n\r\nAnd finally, thank you to you\u2014the one who helped me
    find my dog.\r\n"
  startPosition: {x: 0, y: -500}
  endPosition: {x: 0, y: 500}
  audioSource: {fileID: 553893309}
  endingVoice: {fileID: 8300000, guid: 5b3a6cc7cb865814e8cb9b4ed741a438, type: 3}
